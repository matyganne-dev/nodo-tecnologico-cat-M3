
    <h1>Lista de Superhéroes</h1>

    <table border="1">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Nombre Real</th>
                <th>Edad</th>
                <th>Poderes</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            <% superheroes.forEach(heroe => { %>
                <tr>
                    <td><%= heroe.Nombre %></td>
                    <td><%= heroe["Nombre Real"] %></td>
                    <td><%= heroe.Edad %></td>
                    <td><%= heroe.Poderes.join(', ') %></td>
                    <td>
                        <a href="/heroes/<%= heroe.id %>/editar">Editar</a> | 
                        <form action="/heroes/<%= heroe.id %>?_method=DELETE" method="POST">
                            <button type="button" onclick="confirmarEliminacion('<%= heroe.id %>', '<%= heroe.Nombre %>')">
                                Eliminar
                            </button>
                        </form>
                    </td>
                </tr>
            <% }); %>
        </tbody>
    </table>

    <script>
        async function confirmarEliminacion(id, nombre) {
            // Etapa 5: Confirmación antes de eliminar
            if (!confirm(`¿Estás seguro que querés eliminar a ${nombre}? Esta acción no se puede deshacer.`)) {
                return;
            }

            try {
                // Etapa 5: Endpoint DELETE /heroes/:id
                const res = await fetch(`/heroes/${id}`, {
                    method: 'DELETE'
                });

                if (res.ok || res.redirected) {
                    // Etapa 6: Refrescar el Dashboard[cite: 6]
                    window.location.reload(); 
                } else {
                    alert("Hubo un error al intentar eliminar al superhéroe.");
                }
            } catch (error) {
                console.error("Error:", error);
                // Paracaídas por si el servidor redirige[cite: 4]
                window.location.href = "/heroes";
            }
        }
    </script>
