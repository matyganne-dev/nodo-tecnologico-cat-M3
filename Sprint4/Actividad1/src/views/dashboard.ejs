<section class="dashboard-container">
    <h1 class="main-title">Registro de Superhéroes</h1>

    <div class="table-wrapper">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Nombre Real</th>
                    <th>Edad</th>
                    <th>Poderes</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                <% superheroes.forEach(heroe=> { %>
                    <tr>
                        <td class="hero-name">
                            <%= heroe.Nombre %>
                        </td>
                        <td>
                            <%= heroe["Nombre Real"] %>
                        </td>
                        <td>
                            <%= heroe.Edad %>
                        </td>
                        <td>
                            <div class="powers-tags">
                                <% heroe.Poderes.forEach(poder=> { %>
                                    <span class="power-tag">
                                        <%= poder %>
                                    </span>
                                    <% }); %>
                            </div>
                        </td>
                        <td class="actions-cell">
                            <a href="/heroes/<%= heroe.id %>/editar" class="btn-edit">Editar</a>
                            <form action="/heroes/<%= heroe.id %>?_method=DELETE" method="POST" style="display:inline;">
                                <button type="button" class="btn-delete"
                                    onclick="confirmarEliminacion('<%= heroe.id %>', '<%= heroe.Nombre %>')">
                                    Eliminar
                                </button>
                            </form>
                        </td>
                    </tr>
                    <% }); %>
            </tbody>
        </table>
    </div>
</section>
<script>
    async function confirmarEliminacion(id, nombre) {
        // Etapa 5: Confirmación antes de eliminar
        if (!confirm(`¿Estás seguro que querés eliminar a ${nombre}? Esta acción no se puede deshacer.`)) {
            return;
        }

        try {
            // Etapa 5: Endpoint DELETE /heroes/:id
            const res = await fetch(`/heroes/${id}`, {
                method: 'DELETE'
            });

            if (res.ok || res.redirected) {
                // Etapa 6: Refrescar el Dashboard[cite: 6]
                window.location.reload();
            } else {
                alert("Hubo un error al intentar eliminar al superhéroe.");
            }
        } catch (error) {
            console.error("Error:", error);
            // Paracaídas por si el servidor redirige[cite: 4]
            window.location.href = "/heroes";
        }
    }
</script>