<section class="form-container">
    <h1>Nuevo País Hispanohablante</h1>
    
    <div id="error-container" style="display: none; background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; padding: 15px; margin-bottom: 20px; border-radius: 4px;">
        <h4 style="margin-top: 0;">Por favor, corrige los siguientes errores:</h4>
        <ul id="error-list"></ul>
    </div>

    <form id="addCountryForm" class="custom-form">
        <div class="form-group">
            <label>Nombre Oficial del País:</label>
            <input type="text" name="officialName" placeholder="Ej: República de Colombia">
        </div>
        <div class="form-group">
            <label>Capital (Separadas por comas si son varias):</label>
            <input type="text" name="capital" placeholder="Ej: Bogotá">
        </div>
        <div class="form-group">
            <label>Área (en km²):</label>
            <input type="number" name="area" placeholder="Ej: 1141748">
        </div>
        <div class="form-group">
            <label>Población Actual:</label>
            <input type="number" name="population" placeholder="Ej: 53057212">
        </div>
        <div class="form-group">
            <label>Índice Gini (0-100 Opcional):</label>
            <input type="number" step="0.1" name="gini" placeholder="Ej: 51.3">
        </div>
        <div class="form-group">
            <label>Límites / Fronteras (3 letras separados por coma):</label>
            <input type="text" name="borders" placeholder="Ej: BRA, ECU, PAN, PER, VEN">
        </div>
        <div class="form-group">
            <label>Husos Horarios (Separados por coma - Opcional):</label>
            <input type="text" name="timezones" placeholder="Ej: UTC-05:00, UTC-04:00">
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-save">Guardar País</button>
            <a href="/paises" class="btn-cancel">Cancelar</a>
        </div>
    </form>
</section>

<script>
    document.getElementById("addCountryForm").addEventListener("submit", async (e) => {
        e.preventDefault();
        const form = e.target;

        const errorContainer = document.getElementById("error-container");
        const errorList = document.getElementById("error-list");
        errorContainer.style.display = "none";
        errorList.innerHTML = "";

        // --- VALIDACIÓN POR SCRIPT EN EL FRONTEND ---
        const erroresFrontend = [];
        
        if (!form.officialName.value.trim()) erroresFrontend.push("El nombre oficial del país es obligatorio.");
        if (!form.capital.value.trim()) erroresFrontend.push("La capital es obligatoria.");
        if (!form.area.value.trim()) erroresFrontend.push("El área es obligatoria.");
        if (!form.population.value.trim()) erroresFrontend.push("La población es obligatoria.");

        // Si detectamos campos vacíos en el Frontend, frenamos acá y los mostramos estéticamente
        if (erroresFrontend.length > 0) {
            errorContainer.style.display = "block";
            erroresFrontend.forEach(msg => {
                const li = document.createElement("li");
                li.textContent = msg;
                errorList.appendChild(li);
            });
            return; // Detiene el envío
        }

        const body = {
            officialName: form.officialName.value.trim(),
            capital: form.capital.value.trim(),
            area: form.area.value,
            population: form.population.value,
            gini: form.gini.value ? form.gini.value : null,
            borders: form.borders.value.trim(),
            timezones: form.timezones.value.trim()
        };

        try {
            const res = await fetch("/paises/agregar", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(body)
            });

            const data = await res.json();

            if (res.ok) {
                alert("¡País guardado exitosamente!");
                window.location.href = "/paises";
            } else if (res.status === 400 && data.errors) {
                // Muestra los errores minuciosos devueltos por el backend (express-validator)
                errorContainer.style.display = "block";
                data.errors.forEach(err => {
                    const li = document.createElement("li");
                    li.textContent = `${err.mensaje}`;
                    errorList.appendChild(li);
                });
            } else {
                alert(data.mensaje || "Error al intentar guardar el país.");
            }
        } catch (error) {
            console.error("Error de red:", error);
            alert("No se pudo conectar con el servidor.");
        }
    });
</script>