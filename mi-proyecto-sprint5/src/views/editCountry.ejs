<section class="form-container">
    <h1>Editar País: <%= pais.name && pais.name.official ? pais.name.official : '' %></h1>

    <div id="error-container" style="display: none; background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; padding: 15px; margin-bottom: 20px; border-radius: 4px;">
        <h4 style="margin-top: 0;">Por favor, corrige los siguientes errores:</h4>
        <ul id="error-list"></ul>
    </div>

    <form id="editCountryForm" class="custom-form">
        <div class="form-group">
            <label>Nombre Oficial del País:</label>
            <input type="text" name="officialName" value="<%= pais.name && pais.name.official ? pais.name.official : '' %>" required>
        </div>
        <div class="form-group">
            <label>Capital:</label>
            <input type="text" name="capital" value="<%= pais.capital ? pais.capital.join(', ') : '' %>" required>
        </div>
        <div class="form-group">
            <label>Área (en km²):</label>
            <input type="number" name="area" value="<%= pais.area %>" required>
        </div>
        <div class="form-group">
            <label>Población:</label>
            <input type="number" name="population" value="<%= pais.population %>" required>
        </div>
        <div class="form-group">
            <label>Índice Gini:</label>
            <input type="number" step="0.1" name="gini" value="<%= (pais.gini !== null && pais.gini !== undefined) ? pais.gini : '' %>">
        </div>
        <div class="form-group">
            <label>Fronteras / Borders (separados por coma):</label>
            <input type="text" name="borders" value="<%= pais.borders ? pais.borders.join(', ') : '' %>">
        </div>
        <div class="form-group">
            <label>Husos Horarios (separados por coma):</label>
            <input type="text" name="timezones" value="<%= pais.timezones ? pais.timezones.join(', ') : '' %>">
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-save">Actualizar País</button>
            <a href="/paises" class="btn-cancel">Cancelar</a>
        </div>
    </form>
</section>

<script>
    document.getElementById("editCountryForm").addEventListener("submit", async (e) => {
        e.preventDefault();
        const form = e.target;

        const errorContainer = document.getElementById("error-container");
        const errorList = document.getElementById("error-list");
        errorContainer.style.display = "none";
        errorList.innerHTML = "";

        const body = {
            officialName: form.officialName.value.trim(),
            capital: form.capital.value.trim(),
            area: form.area.value,
            population: form.population.value,
            gini: form.gini.value ? form.gini.value : null,
            borders: form.borders.value.trim(),
            timezones: form.timezones.value.trim()
        };

        try {
            const res = await fetch("/paises/<%= pais._id %>/editar", {
                method: "PUT",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(body)
            });

            const data = await res.json();

            if (res.ok) {
                alert("¡País actualizado con éxito!");
                window.location.href = "/paises"; 
            } else if (res.status === 400 && data.errors) {
                errorContainer.style.display = "block";
                data.errors.forEach(err => {
                    const li = document.createElement("li");
                    li.textContent = `${err.mensaje}`;
                    errorList.appendChild(li);
                });
            } else {
                alert(data.mensaje || "Error en el servidor al intentar actualizar.");
            }
        } catch (err) {
            console.error("Error de red:", err);
            alert("No se pudo conectar con el servidor.");
        }
    });
</script>